# ========================================
# 小蚁搬运 - 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# ========================================

# 服务端口
BACKEND_PORT=3000

# 运行环境: development | production | test
NODE_ENV=development

# ---- 数据库配置 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=xiaoyi_banyun

# ---- JWT 认证 ----
# 必须设置！不能留空或使用默认值
JWT_SECRET=your_strong_random_secret_here

# ---- 高德地图 API ----
AMAP_KEY=your_amap_api_key_here

# ---- CORS 配置 ----
# 逗号分隔的允许来源，例如: https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# ---- 前端地址（用于推荐链接等） ----
FRONTEND_URL=https://xiaoyibanyun.com
